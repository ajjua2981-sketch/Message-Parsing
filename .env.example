# Kafka (on-prem cluster)
# Comma-separated list of broker host:port pairs
KAFKA_BOOTSTRAP_SERVERS=broker1:9092,broker2:9092,broker3:9092
KAFKA_TOPIC=your-topic-name
KAFKA_GROUP_ID=message-parsing-group
KAFKA_AUTO_OFFSET_RESET=earliest

# Security: PLAINTEXT | SASL_PLAINTEXT | SASL_SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Auth mechanism: leave blank for none, or set to GSSAPI | PLAIN | SCRAM-SHA-256 | SCRAM-SHA-512
KAFKA_SASL_MECHANISM=

# Kerberos (GSSAPI) — fill in if cluster uses Kerberos
KAFKA_SASL_KERBEROS_SERVICE_NAME=kafka
KAFKA_SASL_KERBEROS_PRINCIPAL=

# LDAP / PLAIN / SCRAM — fill in if cluster uses username/password
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# On-prem tuning (defaults are safe to leave as-is)
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=10000
KAFKA_MAX_POLL_INTERVAL_MS=300000

# Oracle
ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password
ORACLE_DSN=localhost:1521/ORCL

# App
# Dot-notation path to the reference ID field in the XML (adjust to your schema)
REFERENCE_ID_PATH=ns2:Envelope.ns2:body.PAReferenceId
ORACLE_TABLE=YOUR_TABLE_NAME
