# Environment: dev | qa | prod
# All Kafka resource files (keytab, krb5.conf, common.pem) are resolved
# automatically from resources/kafka/<APP_ENV>/
APP_ENV=dev

# Kafka (on-prem cluster)
KAFKA_BOOTSTRAP_SERVERS=your-kafka-broker1:9092,your-kafka-broker2:9092,your-kafka-broker3:9092
KAFKA_TOPIC=your-kafka-topic
KAFKA_GROUP_ID=your-consumer-group-id
KAFKA_AUTO_OFFSET_RESET=earliest

# Auth: Kerberos over SSL
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=GSSAPI
KAFKA_SASL_KERBEROS_SERVICE_NAME=your-kerberos-service-name
KAFKA_SASL_KERBEROS_PRINCIPAL=your-service-account@your-domain.com

# On-prem tuning (safe to leave as-is)
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=10000
KAFKA_MAX_POLL_INTERVAL_MS=300000

# Oracle
ORACLE_USER=your-oracle-username
ORACLE_PASSWORD=your-oracle-password
ORACLE_DSN=your-oracle-host:1521/your-service-name
ORACLE_TABLE=your-table-name

# App
REFERENCE_ID_PATH=ns2:Envelope.ns2:body.PAReferenceId
