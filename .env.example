# Kafka (on-prem dev cluster)
KAFKA_BOOTSTRAP_SERVERS=ch3dr1017045.express-scripts.com:9092,ch3dr1017046.express-scripts.com:9092,ch3dr1017047.express-scripts.com:9092,ch3dr1017048.express-scripts.com:9092,ch3dr1017049.express-scripts.com:9092,ch3dr1017050.express-scripts.com:9092
KAFKA_TOPIC=your-topic-name
KAFKA_GROUP_ID=message-parsing-group
KAFKA_AUTO_OFFSET_RESET=earliest

# Auth: Kerberos over SSL (on-prem cluster)
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=GSSAPI
KAFKA_SASL_KERBEROS_SERVICE_NAME=cdkafka
KAFKA_SASL_KERBEROS_PRINCIPAL=svc-account@EXPRESS-SCRIPTS.COM

# Environment: dev | qa | uat | prod
APP_ENV=dev

# Keytab path — place the keytab file in the matching resources/kafka/<env>/ folder
KEYTAB_FILE=resources/kafka/dev/dev.keytab

# SSL: path to common.pem (place the file in the project root or provide full path)
KAFKA_SSL_CA_LOCATION=common.pem

# On-prem tuning (safe to leave as-is)
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=10000
KAFKA_MAX_POLL_INTERVAL_MS=300000

# Oracle
ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password
ORACLE_DSN=localhost:1521/ORCL

# App
# Dot-notation path to the reference ID field in the XML (adjust to your schema)
REFERENCE_ID_PATH=ns2:Envelope.ns2:body.PAReferenceId
ORACLE_TABLE=YOUR_TABLE_NAME
